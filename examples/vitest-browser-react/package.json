    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/browser": "^3.0.0",
    "playwright": "^1.50.0",
    "typescript": "^6.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vitest-browser-react": "^1.0.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
