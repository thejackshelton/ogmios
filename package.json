{
  "name": "shoki-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Screen-reader test automation — monorepo root",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r --filter=./packages/* typecheck",
    "test": "pnpm -r --filter=./packages/* test",
    "build": "pnpm -r --filter=./packages/* build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^6.0.0"
  }
}
