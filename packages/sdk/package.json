{
  "name": "@shoki/sdk",
  "version": "0.0.0",
  "description": "Screen-reader test automation SDK — TypeScript surface + CLI + matchers for Shoki's Zig native core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoki/shoki.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shoki": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./matchers": {
      "types": "./dist/matchers/index.d.ts",
      "import": "./dist/matchers/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "picocolors": "^1.0.0"
  },
  "optionalDependencies": {
    "@shoki/binding-darwin-arm64": "workspace:*",
    "@shoki/binding-darwin-x64": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "vitest": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "screen-reader",
    "voiceover",
    "accessibility",
    "testing",
    "vitest",
    "doctor",
    "cli",
    "tcc"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
