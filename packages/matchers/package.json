{
  "name": "@shoki/matchers",
  "version": "0.0.0",
  "description": "Vitest expect matchers for Shoki ShokiEvent[] screen-reader logs (toHaveAnnounced, toHaveAnnouncedText, toHaveNoAnnouncement, toHaveStableLog)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoki/shoki.git",
    "directory": "packages/matchers"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@shoki/sdk": "workspace:*",
    "vitest": "^3.0.0"
  },
  "devDependencies": {
    "@shoki/sdk": "workspace:*",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "shoki",
    "vitest",
    "matchers",
    "expect",
    "screen-reader",
    "voiceover",
    "accessibility",
    "testing"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
