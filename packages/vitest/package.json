{
  "name": "@shoki/vitest",
  "version": "0.0.0",
  "description": "Vitest browser-mode plugin for Shoki — BrowserCommands bridge + expect.extend wiring for @shoki/sdk/matchers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoki/shoki.git",
    "directory": "packages/vitest"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@shoki/sdk": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "^3.0.0 || ^4.0.0",
    "@vitest/browser": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@shoki/sdk": "workspace:*",
    "@types/node": "^24.0.0",
    "@vitest/browser": "^3.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "shoki",
    "vitest",
    "browser-mode",
    "matchers",
    "screen-reader",
    "voiceover",
    "accessibility"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
