{
  "name": "@shoki/doctor",
  "version": "0.0.0",
  "description": "shoki doctor — diagnose and (where possible) fix VoiceOver / TCC / helper state on macOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoki/shoki.git",
    "directory": "packages/doctor"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shoki": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@shoki/sdk": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "screen-reader",
    "voiceover",
    "accessibility",
    "macos",
    "doctor",
    "cli",
    "tcc"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
